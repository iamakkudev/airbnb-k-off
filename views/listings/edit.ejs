<% layout('/layout/boilerplate.ejs') %>
<body>
    <div class="row mt-3 mb-3">
        <div class="col-8 offset-2">
            <h3>Edit the listing</h3>
            <form method="post" action="/listings/<%= listing._id %>?_method=PUT">
                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input type="text" name="title" id="title" class=" form-control shadow-focus" placeholder="Enter the title" value="<%= listing.title %>"  required>
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea name="description" id="description" class=" form-control shadow-focus" placeholder="Enter the description" ><%= listing.description %></textarea>
                </div>

                <div class="mb-3">
                    <label for="image" class="form-label">Imag URL</label>
                    <input type="text" name="image" id="image" class=" form-control shadow-focus" placeholder="Enter the image URL" value="<%= listing.image %>">
                </div>

                <div class="row">
                    <div class="mb-3 col-4">
                        <label for="price" class="form-label">Price</label>
                        <input type="number" name="price" id="price" class=" form-control shadow-focus" placeholder="eg.- 1200" value="<%= listing.price %>" required>
                    </div>

                    <div class="mb-3 col-8">
                        <label for="location" class="form-label">Location</label>
                        <input type="text" name="location" id="location" class=" form-control shadow-focus" placeholder="Enter the location" value="<%= listing.location %>">
                    </div>
                </div>

                <div class="mb-3">
                    <label for="country" class="form-label">Country</label>
                    <input type="text" name="country" id="country" class=" form-control shadow-focus" value="<%= listing.country %>" placeholder="India">
                </div>
                
                <button type="submit" class="btn mb-3 add-button">Submit</button>
            </form>
        </div>
    </div>
